{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UartRemote",
  "version": "0.1.0",
  "identifier": "com.uartremote.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UartRemote",
        "width": 1000,
        "height": 700,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
